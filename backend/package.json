{
  "name": "@nutrivoice/backend",
  "version": "1.0.0",
  "description": "Backend API for NutriVoice AI Diet Planner",
  "main": "src/index.ts",
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "start": "bun dist/index.js",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "lint": "eslint src --ext .ts",
    "migrate": "bun src/db/migrate.ts",
    "seed": "bun src/db/seed.ts"
  },
  "dependencies": {
    "@nutrivoice/shared": "workspace:*",
    "hono": "^3.12.0",
    "mysql2": "^3.6.5",
    "bcrypt": "^5.1.1",
    "jsonwebtoken": "^9.0.2",
    "speakeasy": "^2.0.0",
    "qrcode": "^1.5.3",
    "ioredis": "^5.3.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.10.6",
    "@types/qrcode": "^1.5.5",
    "@types/speakeasy": "^2.0.10",
    "bun-types": "^1.0.20",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "vitest": "^1.1.0",
    "fast-check": "^3.15.0",
    "supertest": "^6.3.3",
    "@types/supertest": "^6.0.2"
  }
}
